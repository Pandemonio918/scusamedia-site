  "outputDirectory": ".",
  "redirects": [
    { "source": "/about", "destination": "/#who-we-serve", "permanent": true },
    { "source": "/services", "destination": "/#services", "permanent": true },
    { "source": "/get-started", "destination": "/#contact", "permanent": true },
