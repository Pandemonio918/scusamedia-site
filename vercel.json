    { "source": "/privacy", "destination": "/legal.html#privacy", "permanent": true },
    { "source": "/terms", "destination": "/legal.html#terms", "permanent": true },
    { "source": "/privacy-policy", "destination": "/legal.html#privacy", "permanent": true },
    { "source": "/terms-of-service", "destination": "/legal.html#terms", "permanent": true }
